{
	"compilerOptions": {
		"target": "es2020",
		"lib": ["ES2020", "WebWorker"],
		"sourceMap": true,
    "types": ["node", "@somesass/language-services"],
		"module": "preserve",
		"moduleResolution": "bundler",
		"outDir": "out",
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true
	},
	"exclude": ["**/*.test.ts", "vitest.config.mts"]
}
